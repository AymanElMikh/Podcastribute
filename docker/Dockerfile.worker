# ──────────────────────────────────────────────────────────────
# Celery worker — same deps as the API, different CMD
# ──────────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
RUN mkdir -p api worker && touch api/__init__.py worker/__init__.py

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --upgrade pip && \
    pip install --no-cache-dir .

# ──────────────────────────────────────────────────────────────
FROM python:3.12-slim

RUN groupadd -r app && useradd -r -g app -u 1000 app

WORKDIR /app

# ffmpeg required for audio conversion; whisper for transcription
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    ffmpeg \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY api/ ./api/
COPY worker/ ./worker/

RUN mkdir -p /uploads && chown app:app /uploads && \
    mkdir -p /tmp/whisper_models && chown -R app:app /tmp/whisper_models

# Pre-download faster-whisper model at build time (avoids runtime internet access).
# Uses int8 quantization for 4x faster CPU inference vs openai-whisper.
ARG WHISPER_MODEL=small
RUN python -c "\
from faster_whisper import WhisperModel; \
WhisperModel('$WHISPER_MODEL', device='cpu', compute_type='int8', download_root='/tmp/whisper_models')"

USER app

# 2 concurrent tasks; late ack so jobs aren't lost on crash
CMD ["celery", "-A", "worker.celery_app", "worker", \
     "--concurrency=2", "--loglevel=info"]
