# ══════════════════════════════════════════════════════════════════
# PodcastAI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL_DEFAULT=gpt-4o-mini
OPENAI_MODEL_QUALITY=gpt-4o

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/podcastai

# Redis / Celery
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/1

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_CREATOR=price_creator_id_here
STRIPE_PRICE_STUDIO=price_studio_id_here

# Audio Processing
WHISPER_MODEL=small
UPLOADS_DIR=/uploads
MAX_UPLOAD_MB=500

# Auth
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256

# Runtime
ENVIRONMENT=development
# CORS — comma-separated allowed origins. Leave empty to allow all.
CORS_ORIGINS=

# Docker Compose — Postgres credentials (used by docker/docker-compose.yml)
POSTGRES_USER=podcastai
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_DB=podcastai

# Frontend (exposed to the browser)
NEXT_PUBLIC_API_URL=https://podcast.yourdomain.com
